{
  "$schema": "../../../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "OpenCode",
  "version": "1.16.0",
  "identifier": "ai.opencode.mobile",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "node ../../node_modules/vite/bin/vite.js ../app",
    "beforeBuildCommand": "node ../../node_modules/vite/bin/vite.js build ../app --outDir ../mobile/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "OpenCode",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
